# X (Twitter) API
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database
DATABASE_URL=

# App
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development
CRON_SECRET=

# xAI Grok (optional — falls back to Claude if not set)
GROK_API_KEY=

# Brand identity — keep personal details out of code
X_HANDLE=@yourusername
NEXT_PUBLIC_X_HANDLE=@yourusername
X_USER_ID=your_twitter_numeric_user_id
DISPLAY_INITIAL=Y

# Niche & content — comma-separated, defines what Phantom talks about and who it engages with
NICHE_KEYWORDS=your niche keyword,another keyword,third keyword
CONTENT_TOPICS=your content topic 1,your content topic 2,your content topic 3
THREAD_TOPICS=thread angle 1,thread angle 2,thread angle 3
VOICE_TOPICS=your niche,your expertise,your style

# Engagement blocklist — comma-separated, never commit real values
BLOCKED_USERNAMES=
BLOCKED_IDS=
