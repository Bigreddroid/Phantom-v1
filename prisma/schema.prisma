generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Multi-tenant user accounts ────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  name               String?
  stripeCustomerId   String?
  stripeSubscriptionId String?
  plan               String    @default("free")          // free | starter | pro
  subscriptionStatus String    @default("inactive")      // inactive | trialing | active | canceled | past_due
  trialEndsAt        DateTime?
  onboardingStep     Int       @default(0)               // 0=not started, 1=x, 2=telegram, 3=voice, 4=done
  onboardingDone     Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  xCredential        XCredential?
  telegramSetup      TelegramSetup?
  userSettings       UserSettings?
}

model XCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  authMethod   String   @default("cookies")  // "cookies" | "api"
  cookies      String?                         // JSON array of cookie strings (authMethod="cookies")
  username     String
  xUserId      String?
  // Official X API keys (authMethod="api") — stored encrypted at rest by Supabase
  apiKey       String?
  apiSecret    String?
  accessToken  String?
  accessSecret String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model TelegramSetup {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  botToken   String
  chatId     String
  webhookSet Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  handle           String   @default("")
  timezone         String   @default("Asia/Kolkata")
  nicheKeywords    String   @default("")  // comma-separated
  contentTopics    String   @default("")
  threadTopics     String   @default("")
  voiceTopics      String   @default("")
  voiceDescription String   @default("")  // free-text voice/tone description
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── Existing tables — userId added as nullable for backward compat ─────────────
// Varun's legacy records have userId = null. New user records have userId set.

model QueueItem {
  id        String      @id @default(cuid())
  userId    String?
  type      String
  content   String
  metadata  Json?
  status    QueueStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  detail    String?
  icon      String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Stats {
  id            String   @id @default("singleton")
  userId        String?  @unique
  followers     Int      @default(0)
  following     Int      @default(0)
  tweets        Int      @default(0)
  engagements   Int      @default(0)
  dmsSent       Int      @default(0)
  paused        Boolean  @default(false)
  lastMentionId String?
  updatedAt     DateTime @updatedAt
}

model BlockedAccount {
  id        String   @id @default(cuid())
  userId    String?
  username  String
  createdAt DateTime @default(now())

  @@unique([userId, username])
}

model LinkedInAuth {
  id           String    @id @default("singleton")
  userId       String?   @unique
  accessToken  String
  refreshToken String?
  personId     String
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model XSession {
  id        String   @id @default("singleton")
  userId    String?  @unique
  cookies   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model BrainMemory {
  id        String   @id @default(cuid())
  userId    String?
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
}

model ConversationThread {
  id              String   @id @default(cuid())
  userId          String?
  twitterUserId   String
  twitterUsername String
  messages        Json
  updatedAt       DateTime @updatedAt

  @@unique([userId, twitterUserId])
}

model PerformanceInsight {
  id        String   @id @default(cuid())
  userId    String?
  insight   String
  metric    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

enum QueueStatus {
  PENDING
  APPROVED
  REJECTED
  POSTED
}

// ── V2: Lead Generation ───────────────────────────────────────────────────────

enum LeadStage {
  DISCOVERED
  WARMING
  DM_SENT
  RESPONDED
  CONVERTED
  REMOVED
}

model ICPConfig {
  id                String   @id @default(cuid())
  userId            String?  @unique
  keywords          String[]
  competitorHandles String[]
  hashtags          String[]
  minFollowers      Int      @default(500)
  maxFollowers      Int      @default(100000)
  warmthThreshold   Int      @default(60)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LeadProfile {
  id            String       @id @default(cuid())
  userId        String?
  twitterUserId String
  username      String
  bio           String?
  recentTweets  Json?
  aiSummary     String?
  warmthScore   Int          @default(0)
  dmHistory     Json?
  notes         String?
  stage         LeadStage    @default(DISCOVERED)
  sourceKeyword String?
  discoveredAt  DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  activities    LeadActivity[]

  @@unique([userId, twitterUserId])
  @@index([userId, stage])
}

model LeadActivity {
  id        String      @id @default(cuid())
  leadId    String
  lead      LeadProfile @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  detail    String?
  createdAt DateTime    @default(now())

  @@index([leadId])
}

model OutreachTemplate {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  body      String
  category  String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
